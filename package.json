{
  "name": "@creact-labs/creact-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "libs/*",
    "libs/examples/apps/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/creact",
    "test": "npm test -w packages/creact",
    "typecheck": "npm run typecheck -w packages/creact",
    "coverage:all": "npm run test:coverage -w packages/creact && vitest --run --coverage --root packages/testing && vitest --run --coverage --root apps/website && npm run coverage:merge",
    "coverage:merge": "node scripts/merge-coverage.mjs coverage/coverage-final.json packages/creact/coverage/coverage-final.json packages/testing/coverage/coverage-final.json apps/website/coverage/coverage-final.json",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "author": "Daniel Coutinho Ribeiro <dcoutinho.96@gmail.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/creact-labs/creact.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "prettier": "^3.6.2",
    "typescript": "^5.0.0"
  }
}
