{
  "name": "@creact-labs/vite-plugin",
  "version": "0.4.0",
  "type": "module",
  "description": "Vite plugin for CReact — zero-config JSX so Vite and Vitest build CReact projects",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": ["dist"],
  "keywords": ["creact", "vite", "vite-plugin", "jsx"],
  "scripts": {
    "build": "tsc",
    "test": "vitest --run",
    "typecheck": "tsc --noEmit"
  },
  "author": "Daniel Coutinho Ribeiro <dcoutinho.96@gmail.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/creact-labs/creact.git",
    "directory": "packages/vite-plugin"
  },
  "peerDependencies": {
    "vite": ">=5"
  },
  "devDependencies": {
    "vite": "^6.0.0",
    "vitest": "^3.2.7"
  }
}
