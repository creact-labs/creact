{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "declaration": false,
    "jsx": "react-jsx",
    "jsxImportSource": "./src/jsx",
    "paths": {
      "@creact-labs/creact": ["./src"],
      "@creact-labs/creact/jsx-runtime": ["./src/jsx/jsx-runtime"]
    }
  },
  "include": ["src/**/*"]
}
