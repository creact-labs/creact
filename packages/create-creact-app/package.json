{
  "name": "create-creact-app",
  "version": "0.0.1",
  "type": "module",
  "description": "Scaffold a new CReact project — npm create creact-app@latest my-app",
  "main": "dist/src/index.js",
  "bin": {
    "create-creact-app": "dist/src/cli.js"
  },
  "files": ["dist"],
  "keywords": ["creact", "create", "scaffold", "starter", "template"],
  "scripts": {
    "build": "tsc",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "typecheck": "tsc --noEmit"
  },
