{
  "name": "create-creact-app",
  "version": "0.1.1",
  "type": "module",
  "description": "Scaffold a new CReact project — npm create creact-app@latest my-app",
  "main": "dist/src/index.js",
  "bin": {
    "create-creact-app": "dist/src/cli.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "creact",
    "create",
    "scaffold",
    "starter",
    "template"
  ],
  "scripts": {
    "build": "tsc && tsc-alias -p tsconfig.json --resolve-full-paths",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "author": "Daniel Coutinho Ribeiro <dcoutinho.96@gmail.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/creact-labs/creact.git",
    "directory": "packages/create-creact-app"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "tsc-alias": "^1.9.1",
    "vitest": "^3.2.7"
  }
}
